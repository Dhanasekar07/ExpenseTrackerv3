<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2E7D32"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💰 Expense Tracker"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#A5D6A7"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnSetup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙ Setup"
                    android:textColor="#FFFFFF"
                    android:background="#1B5E20"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"/>
            </LinearLayout>

            <!-- FILTER TABS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btnToday"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="Today"
                    android:textSize="12sp"
                    android:background="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnWeek"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="Week"
                    android:textSize="12sp"
                    android:background="#388E3C"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnMonth"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="Month"
                    android:textSize="12sp"
                    android:background="#388E3C"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnAll"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="All"
                    android:textSize="12sp"
                    android:background="#388E3C"
                    android:textColor="#CCFFFFFF"/>
            </LinearLayout>
        </LinearLayout>

        <!-- TOTAL SPENT CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="-20dp"
            android:layout_marginBottom="8dp">

            <!-- Total Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="6dp"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Spent"
                    android:textColor="#757575"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvTotalSpent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="#2E7D32"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Transactions Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="6dp"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transactions"
                    android:textColor="#757575"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvTotalCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#1565C0"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- BAR GRAPH CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Spending by Category"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- BAR GRAPH VIEW -->
            <com.example.expensetracker.BarGraphView
                android:id="@+id/barGraphView"
                android:layout_width="match_parent"
                android:layout_height="180dp"/>

            <!-- LEGEND -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginEnd="12dp">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="#FF6F00"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" Tea" android:textSize="11sp" android:textColor="#757575"/>
                </LinearLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginEnd="12dp">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="#1565C0"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" Travel" android:textSize="11sp" android:textColor="#757575"/>
                </LinearLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginEnd="12dp">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="#2E7D32"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" Grocery" android:textSize="11sp" android:textColor="#757575"/>
                </LinearLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="#6A1B9A"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" Other" android:textSize="11sp" android:textColor="#757575"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- CATEGORY SUMMARY CARDS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳 Category Breakdown"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/categoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>

        <!-- RECENT TRANSACTIONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="16dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🕐 Recent Transactions"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnClearAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear All"
                    android:textSize="11sp"
                    android:textColor="#F44336"
                    android:background="@android:color/transparent"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/transactionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <TextView
                android:id="@+id/tvNoTransactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No transactions yet.\nMake a payment to start tracking!"
                android:textColor="#BDBDBD"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone"/>

            <!-- TEST BUTTON -->
            <Button
                android:id="@+id/btnTestOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧪 Test Overlay (₹99 fake payment)"
                android:backgroundTint="#6200EE"
                android:textColor="#FFFFFF"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
